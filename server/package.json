{
  "name": "valquiz-server",
  "version": "1.0.0",
  "description": "ValQuiz real-time game engine - Node.js + Valkey",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "docker": "docker run -d --name valquiz-valkey -p 6379:6379 valkey/valkey:8.0-alpine valkey-server --maxmemory 256mb --maxmemory-policy allkeys-lru"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "iovalkey": "^0.3.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "@google/genai": "^0.2.0",
    "@breeth/sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
