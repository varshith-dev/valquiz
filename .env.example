# ValQuiz Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
CORS_ORIGIN=*

# Valkey/Redis (optional - falls back to in-memory)
VALKEY_URL=redis://localhost:6379

# Gemini AI (required for AI quiz generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Breeth Memory Layer (optional)
BREETH_API_KEY=your_breeth_api_key_here

# OQENS Image Upload (optional)
OQENS_API_KEY=your_oqens_api_key_here
OQENS_CLOUD_ID=your_cloud_id_here

# Frontend (client/.env)
VITE_BACKEND_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
