{
  "cleanUrls": true,
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
