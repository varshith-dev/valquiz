rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for custom quizzes
    match /quizzes/{quizId} {
      // Anyone can read quizzes (players and host lobby need to fetch questions)
      allow read: if true;
      // Only authenticated hosts can manage quizzes
      allow write: if request.auth != null;
    }
    
    // Rules for completed game sessions
    match /game_sessions/{pin} {
      // Anyone can read game session rankings (players need to check standings)
      allow read: if true;
      // Only authenticated hosts can save the final session results
      allow write: if request.auth != null;
      
      // Players need to register nickname and submit answers
      match /players/{nickname} {
        allow read, write: if true;
      }
      match /answers/{nickname} {
        allow read, write: if true;
      }
    }
  }
}
